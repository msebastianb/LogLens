# LogLens — Environment Variable Reference
# Copy to .env and fill in required values before running docker compose up.
#
# ─── Quick Start with environment presets ──────────────────────────────────────
#
# Development (hot-reload, debug logging, fast bcrypt):
#   docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.dev.yml --profile dev up
#
# Test / CI (fast bcrypt, warn logging, test DB):
#   docker compose --env-file .env.test -f docker-compose.yml -f docker-compose.dev.yml --profile test up
#
# Production (uses .env — you must create it from this template):
#   docker compose --profile app up -d
#
# ─── Compose Profiles ─────────────────────────────────────────────────────────
#   (no profile) — infrastructure only: postgres, redis
#   app          — full production stack: postgres, redis, api, scrubber, nginx
#   dev          — same as app, used with docker-compose.dev.yml for hot-reload
#   test         — same as app, used with .env.test for e2e/integration tests
#
# ─── Environment Files ────────────────────────────────────────────────────────
#   .env.example — this file; reference of all variables (not loaded by compose)
#   .env.dev     — committed; safe dev defaults (no secrets)
#   .env.test    — committed; safe test defaults (no secrets)
#   .env         — gitignored; your local/production overrides
#   .env.local   — gitignored; personal overrides (highest priority)

# ─── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://loglens:changeme@postgres:5432/loglens

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Required. Redis connection string. Redis runs with no persistence.
REDIS_URL=redis://redis:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Required. Min 32 bytes. Generate with: openssl rand -hex 32
JWT_SECRET=

# Session lifetime in seconds. JWT expiry and Redis cache TTL are kept in sync.
# Default: 28800 (8 hours)
SESSION_TTL_SECONDS=28800

# Max login attempts per minute per IP. Use higher values for dev/test.
# Default: 5
LOGIN_RATE_LIMIT_MAX=5

# bcrypt cost factor. Lower (4) for dev/test speed; keep 12 in production.
# Default: 12
BCRYPT_ROUNDS=12

# ─── OIDC / SSO (optional) ─────────────────────────────────────────────────────
# If set, enables OIDC mode. Username/password login is disabled when OIDC is configured.
# OIDC_ISSUER_URL=https://your-logto-instance/oidc
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Supported values: openai | anthropic | openai-compatible
# Not required at startup — analysis requests fail until configured.
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_BASE_URL=   # Required for openai-compatible (e.g. LM Studio: http://localhost:1234)
# LLM_MODEL=gpt-5.4-mini

# ─── Scrubbing ─────────────────────────────────────────────────────────────────
# Maximum log payload size in MB. Requests exceeding this are rejected with 413.
MAX_LOG_SIZE_MB=10

# Timeout (ms) for calls to the FastAPI scrubber service.
SCRUBBER_TIMEOUT_MS=30000

# Enable NER-based PII detection in the scrubber.
# WARNING: The NER model runs at ~130 chars/sec on CPU — only enable with GPU or small logs.
NER_ENABLED=false

# ─── Security ──────────────────────────────────────────────────────────────────
# Set to true to force HTTP → HTTPS redirect (Nginx). Auto-detected for non-localhost.
# HTTPS_ONLY=false

# ─── Logging ───────────────────────────────────────────────────────────────────
# Log level for all services: trace | debug | info | warn | error
LOG_LEVEL=info

# ─── PostgreSQL service (used by postgres container) ───────────────────────────
POSTGRES_USER=loglens
POSTGRES_PASSWORD=changeme
POSTGRES_DB=loglens
