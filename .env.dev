# LogLens — Development environment defaults
# Usage: docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.dev.yml up
#
# This file is committed to the repo with safe, non-secret defaults.
# Override any value in a gitignored .env.local or via shell exports.

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://loglens:changeme@postgres:5432/loglens
POSTGRES_USER=loglens
POSTGRES_PASSWORD=changeme
POSTGRES_DB=loglens

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Dev-only secret — never use in production
JWT_SECRET=dev-only-jwt-secret-must-be-at-least-32-chars-long

# Faster bcrypt for dev (4 rounds vs 12 in prod)
BCRYPT_ROUNDS=4

# Higher rate limit for dev convenience
LOGIN_RATE_LIMIT_MAX=100

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Uncomment and configure for your local LLM setup
# LLM_PROVIDER=openai-compatible
# LLM_API_KEY=not-needed
# LLM_BASE_URL=http://host.docker.internal:1234
LLM_MODEL=gpt-4.1-mini

# ─── Scrubbing ─────────────────────────────────────────────────────────────────
MAX_LOG_SIZE_MB=10
SCRUBBER_TIMEOUT_MS=30000
NER_ENABLED=false

# ─── Security ─────────────────────────────────────────────────────────────────
HTTPS_ONLY=false

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
