# LogLens — Test / CI environment defaults
# Usage: docker compose --env-file .env.test -f docker-compose.yml -f docker-compose.dev.yml --profile test up
#
# This file is committed to the repo with safe, non-secret defaults.
# Optimised for fast, deterministic test execution.

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://loglens:changeme@postgres:5432/loglens_test
POSTGRES_USER=loglens
POSTGRES_PASSWORD=changeme
POSTGRES_DB=loglens_test

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Test-only secret — never use in production
JWT_SECRET=test-only-jwt-secret-must-be-at-least-32-chars-long

# Minimum bcrypt rounds for speed
BCRYPT_ROUNDS=4

# No rate limiting in tests
LOGIN_RATE_LIMIT_MAX=1000

# Short session for testing expiry
SESSION_TTL_SECONDS=3600

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Configure for your test LLM (e.g. local model or mock)
# LLM_PROVIDER=openai-compatible
# LLM_API_KEY=not-needed
# LLM_BASE_URL=http://host.docker.internal:1234
LLM_MODEL=gpt-4.1-mini

# ─── Scrubbing ─────────────────────────────────────────────────────────────────
MAX_LOG_SIZE_MB=10
SCRUBBER_TIMEOUT_MS=10000
NER_ENABLED=false

# ─── Security ─────────────────────────────────────────────────────────────────
HTTPS_ONLY=false

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=warn
